# 复制此文件为 .env.local 并填入真实值
# .env.local 已被 .gitignore 排除，不会提交到 git

# === Gemini Vision API（拍照测水位用）===
# 从 https://aistudio.google.com/app/apikey 创建免费 key
GEMINI_API_KEY=

# === Web Push 通知 ===
# 一次性生成：npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com

# 客户端要读这个 public key — 必须 VITE_ 前缀
VITE_VAPID_PUBLIC_KEY=

# Cron 触发的鉴权 secret（GitHub Actions 跟 Vercel env 用同一个值）
CRON_SECRET=

# === Vercel KV / Upstash Redis ===
# 生产环境由 Vercel 自动注入（Storage → Browse Marketplace → Upstash for Redis）
# 本地测试可去 https://console.upstash.com/ 建一个免费 Redis 填这两个值
KV_REST_API_URL=
KV_REST_API_TOKEN=
